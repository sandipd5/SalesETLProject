{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "salesetlproject"
		},
		"DestAzureDataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DestAzureDataLake'"
		},
		"SpurceDBAzureSql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SpurceDBAzureSql'"
		},
		"DestAzureDataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://etlprojectdemo.dfs.core.windows.net/"
		},
		"SpurceDBAzureSql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "otctaserver.database.windows.net"
		},
		"SpurceDBAzureSql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "salesdb"
		},
		"SpurceDBAzureSql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminsand"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "salesetlproject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"DestAzureDataLake_accountKey": {
						"value": "[parameters('DestAzureDataLake_accountKey')]"
					},
					"SpurceDBAzureSql_password": {
						"value": "[parameters('SpurceDBAzureSql_password')]"
					},
					"DestAzureDataLake_properties_typeProperties_url": {
						"value": "[parameters('DestAzureDataLake_properties_typeProperties_url')]"
					},
					"SpurceDBAzureSql_properties_typeProperties_server": {
						"value": "[parameters('SpurceDBAzureSql_properties_typeProperties_server')]"
					},
					"SpurceDBAzureSql_properties_typeProperties_database": {
						"value": "[parameters('SpurceDBAzureSql_properties_typeProperties_database')]"
					},
					"SpurceDBAzureSql_properties_typeProperties_userName": {
						"value": "[parameters('SpurceDBAzureSql_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}